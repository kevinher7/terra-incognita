TI_ENVIRONMENT=local
# TI_GIT_SHA is auto-derived from `git rev-parse` when unset.

# --- S3 (floci locally / real AWS S3 in prod) ---
TI_S3_BUCKET=terra-incognita
MLFLOW_S3_ENDPOINT_URL=http://localhost:4566
AWS_ACCESS_KEY_ID=test
AWS_SECRET_ACCESS_KEY=test

# --- MLflow ---
MLFLOW_TRACKING_URI=http://localhost:5000

# --- OpenTelemetry ---
# Local SigNoz OTLP/HTTP ingest; swap to the Hetzner endpoint in prod.
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318
# OTEL_EXPORTER_OTLP_HEADERS=authorization=Bearer <token>   # deployed sink only

# --- Runtime / Provenance ---
TI_DEVICE=auto
TI_INSTANCE_TYPE=local-mps
