# Copy to .env for local runs. Local/prod parity: the SAME code runs in both; only
# these values change (PLAN §2/§9, observability.md "Sinks"). Nothing is hardcoded.

# --- identity / provenance ---
TI_ENVIRONMENT=local
# TI_GIT_SHA is auto-derived from `git rev-parse` when unset.

# --- S3 (floci locally / real AWS S3 in prod) ---
TI_S3_BUCKET=terra-incognita
MLFLOW_S3_ENDPOINT_URL=http://localhost:4566
AWS_ACCESS_KEY_ID=test
AWS_SECRET_ACCESS_KEY=test

# --- MLflow ---
MLFLOW_TRACKING_URI=http://localhost:5000

# --- OpenTelemetry (the only sink delta between local and prod) ---
# Local SigNoz OTLP/HTTP ingest; swap to the Hetzner/Honeycomb endpoint in prod.
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318
# OTEL_EXPORTER_OTLP_HEADERS=authorization=Bearer <token>   # deployed sink only

# --- training ---
TI_DEVICE=auto
TI_INSTANCE_TYPE=local-mps
TI_EPOCHS=50
TI_SEED=42
